# ─── Local Development (individual vars) ────────────────────────────────────
# Leave DATABASE_URL blank locally; knex.js will use the vars below instead.
DATABASE_URL=

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_password
DB_DATABASE=neekz

# ─── Render Production (set these in Render Dashboard → Environment) ─────────
# Render gives you a single DATABASE_URL for the managed PostgreSQL instance.
# Set DATABASE_URL to that value and leave the DB_* vars blank.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

PORT=5000
NODE_ENV=development
# production on Render: NODE_ENV=production

# Generate strong random secrets for production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-32

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins
# Local:       FRONTEND_URL=http://localhost:3000
# Production:  FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
